rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the requesting user is an administrator
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.role == 'admin' || 
         request.auth.token.role == 'superadmin' ||
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin']);
    }

    // Config Collection rules
    match /config/survey_questions {
      allow read: if true; // Anyone can read questions to fill out the survey
      allow write: if isAdmin(); // Only admins can modify questions
    }

    // Surveys Collection rules
    match /surveys/{uid} {
      // Allow read if user is admin, or if they are requesting their own response
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      
      // Allow create/update for any attendee (authenticated or anonymous submitter)
      allow create, update: if true; 
      
      // Only admin can delete survey responses
      allow delete: if isAdmin();
    }

    // User Profile rules (for Auth Context simulation)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
