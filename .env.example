# Database & Adapter Mode Configuration
# Options: local | firestore | supabase
# - 'local': Runs in pure offline mode using browser LocalStorage (no setup needed).
# - 'firestore': Connects to Google Cloud Firestore (requires Firebase config below).
# - 'supabase': Connects to Supabase / PostgreSQL (requires Supabase config below).
VITE_DATABASE_TYPE=local

# Firebase Credentials (required if VITE_DATABASE_TYPE=firestore)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_USE_EMULATORS=false

# Supabase Credentials (required if VITE_DATABASE_TYPE=supabase)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
